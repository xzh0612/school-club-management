' 关系定义
' 用户与社团：多对一
User "*" -- "1" Club : belongs to

' 社团与活动：一对多
Club "1" -- "*" Activity : organizes

' 用户与活动：多对多（通过ActivitySignup）
User "*" -- "*" Activity : participates in

' 用户与活动报名：一对多
User "1" -- "*" ActivitySignup : signs up

' 活动与活动报名：一对多
Activity "1" -- "*" ActivitySignup : has signups

' 用户与公告：一对多（发布）
User "1" -- "*" Announcement : publishes

' 用户与申请：一对多
User "1" -- "*" Application : submits

' 社团与申请：一对多
Club "1" -- "*" Application : receives

' 用户与审批：一对多（申请）
User "1" -- "*" Approval : applies for

' 用户与审批：一对多（审批）
User "1" -- "*" Approval : approves

' 社团与审批：一对多
Club "1" -- "*" Approval : related to

' 活动与审批：一对多
Activity "1" -- "*" Approval : related to

' 用户与操作日志：一对多
User "1" -- "*" OperationLog : generates

@enduml
